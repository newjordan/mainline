# =============================================================================
# Environment Variables for MainLine
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git - it contains secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# Demo Mode
# -----------------------------------------------------------------------------
# Set true to run a full "test drive" without real Supabase/Twilio/payment calls.
# Recommended for first run from GitHub.
DEMO_MODE=true

# -----------------------------------------------------------------------------
# Payment Provider Selection
# -----------------------------------------------------------------------------
# Choose 'none' to run without online payment links.
# Choose 'square' to enable Square-hosted invoice checkout.
PAYMENT_PROVIDER=none

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Public URL for your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public site URL used for generated links and webhook callback URLs
NEXT_PUBLIC_SITE_URL=https://example.com

# Service role key (server-only, bypasses RLS - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Twilio Configuration (SMS/MMS)
# -----------------------------------------------------------------------------
# Get these from: https://console.twilio.com/

# Account SID (starts with 'AC')
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token (keep secret!)
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Your Twilio phone number in E.164 format
TWILIO_PHONE_NUMBER=+15551234567

# Optional: public "call us" line shown on site/legal pages
BUSINESS_PHONE_NUMBER=+15557654321

# -----------------------------------------------------------------------------
# Square Configuration (Optional Payments)
# -----------------------------------------------------------------------------
# Only needed when PAYMENT_PROVIDER=square.
# Get these from: https://developer.squareup.com/apps

# Access token used for Square API calls
SQUARE_ACCESS_TOKEN=EAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Location ID used when creating payment links/orders
SQUARE_LOCATION_ID=Lxxxxxxxxxxxxxxx

# Webhook signature key from your Square webhook subscription
SQUARE_WEBHOOK_SIGNATURE_KEY=webhooks-signature-key

# Optional: choose API environment ('production' or 'sandbox')
SQUARE_ENVIRONMENT=production

# Optional: canonical webhook URL used for signature validation
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-domain.com/api/webhooks/square

# -----------------------------------------------------------------------------
# Operations / Automation
# -----------------------------------------------------------------------------

# Dashboard access allowlist (comma-separated emails, case-insensitive)
# Fail-closed: if unset/empty, nobody can access dashboard routes
ALLOWED_EMAILS=owner@example.com,admin@example.com

# -----------------------------------------------------------------------------
# Optional: Screenshot Capture Safety
# -----------------------------------------------------------------------------
# Screenshot capture defaults to demo mode. Live mode will create/update
# screenshot fixture data and should only be used against a safe Supabase project.
# SCREENSHOT_CAPTURE_MODE=demo
# SCREENSHOT_ALLOW_LIVE_FIXTURE_MUTATION=true
# SCREENSHOT_ADMIN_EMAIL=owner@example.com
# SCREENSHOT_ADMIN_PASSWORD=replace-with-a-unique-password
# Note: SCREENSHOT_ADMIN_EMAIL must also appear in ALLOWED_EMAILS.

# Optional: admin phone for inbound + payment SMS notifications (E.164)
ADMIN_PHONE_NUMBER=+15559876543

# Optional: direct Google review URL used by "Request Review" action
GOOGLE_REVIEW_URL=https://g.page/r/your-google-review-link/review

# Required for secure cron endpoint authentication
CRON_SECRET=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Google Docs API Configuration
# -----------------------------------------------------------------------------
# Create a service account: https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Google Docs API: https://console.cloud.google.com/apis/library/docs.googleapis.com

# Service account email
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key (include the full key with -----BEGIN PRIVATE KEY----- header)
# Note: In .env files, replace newlines with \n
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
